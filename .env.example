# Telegram Bot Token - Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key - Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Gemini model (run: pipenv run python -m scripts.list_models)
GEMINI_MODEL=gemini-2.5-flash

# Poe API (optional) - Get from https://poe.com/api_key
# Use AI_PROVIDER=poe to use Poe instead of Gemini
POE_API_KEY=your_poe_api_key_here
POE_MODEL=shazambot

# AI provider: "gemini" or "poe"
AI_PROVIDER=gemini

# Repo URL for bot buttons (optional)
REPO_URL=https://github.com/ZeroXShazam/MooshAliIsDead
